      "type": {
        "type": "string",
        "enum": [
          "oscillator",
          "filter",
          "envelope",
          "lfo",
          "delay",
          "reverb",
          "distortion",
          "chorus",
          "compressor",
          "eq",
          "limiter"
        ]
      },
      "signal": {
        "type": "string",
        "enum": ["audio", "mod", "event"]
      },
      "parameters": { "type": "object" }
    },
    "allOf": [
      { "if": { "properties": { "type": { "const": "oscillator" } } }, "then": { "properties": { "parameters": { "$ref": "#/$defs/oscillatorParams" } } } },
      { "if": { "properties": { "type": { "const": "filter" } } }, "then": { "properties": { "parameters": { "$ref": "#/$defs/filterParams" } } } },
      { "if": { "properties": { "type": { "const": "envelope" } } }, "then": { "properties": { "parameters": { "$ref": "#/$defs/envelopeParams" } } } },
      { "if": { "properties": { "type": { "const": "lfo" } } }, "then": { "properties": { "parameters": { "$ref": "#/$defs/lfoParams" } } } },
