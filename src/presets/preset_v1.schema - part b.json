      "knee": { "type": "number" },
      "makeup": { "type": "number" },
      "mix": { "type": "number" }
    },
    "required": ["threshold", "ratio", "attack", "release", "knee", "makeup", "mix"],
    "additionalProperties": false
  },

  "eqParams": {
    "type": "object",
    "properties": {
      "lowGain": { "type": "number" },
